{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/neoxfortress/agent-accountability-receipt/schema.json",
  "title": "Agent Accountability Receipt",
  "description": "Tamper-evident, auditor-oriented execution receipt for AI agents used in regulated environments. Default: metadata + hashes. Optional: include content if explicitly configured. v0.1.1 — includes receipt lifecycle management, CUI flow tracking, compliance verdict, deployment fingerprint, Merkle support, step-level error capture, human checkpoint evidence, multi-receipt linkage, and machine-verifiable hash patterns for full C3PAO/prime/IG defensibility. Schema hash is computed on the raw bytes of the published schema.json at the tagged git commit.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt",
    "context",
    "policy",
    "execution",
    "data_handling",
    "integrity"
  ],
  "properties": {
    "receipt": { "$ref": "#/$defs/receipt_header" },
    "context": { "$ref": "#/$defs/context" },
    "policy": { "$ref": "#/$defs/policy_snapshot" },
    "execution": { "$ref": "#/$defs/execution" },
    "data_handling": { "$ref": "#/$defs/data_handling" },
    "integrity": { "$ref": "#/$defs/integrity" },
    "compliance": {
      "type": "object",
      "additionalProperties": false,
      "description": "Self-assessed compliance verdict generated by the engine rule set or by a human reviewer. This is NOT a certification — it is an evidence artifact that supports compliance arguments.",
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["compliant", "non_compliant", "partial", "review_required"],
          "description": "Overall compliance assessment for this agent execution."
        },
        "assessed_by": {
          "type": "string",
          "enum": ["engine_rule_set", "human_reviewer", "hybrid"],
          "description": "Who or what produced this verdict. Critical for auditors to understand the level of assurance."
        },
        "assessor_id": {
          "type": "string",
          "description": "If assessed_by is human_reviewer or hybrid, the principal_id of the reviewer."
        },
        "violated_controls": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of control IDs that were violated (e.g., AC.L2-3.1.1, SC.L2-3.13.1)."
        },
        "risk_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Numeric risk score. 0 = no risk identified, 10 = critical violation."
        },
        "framework": {
          "type": "string",
          "description": "Compliance framework the verdict was assessed against (e.g., CMMC L2, NIST 800-171 r3)."
        },
        "notes": { "type": "string" }
      }
    },
    "cui_flow": {
      "type": "array",
      "description": "End-to-end CUI data flow tracking across boundaries. Per-step classification tags show what was tagged; this array shows where CUI moved. Auditors must prove CUI never improperly crossed boundaries.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["direction", "boundary", "data_hash", "redacted"],
        "properties": {
          "direction": {
            "type": "string",
            "enum": ["in", "out", "internal"],
            "description": "Direction of data flow relative to the agent execution boundary."
          },
          "boundary": {
            "type": "string",
            "description": "Human-readable boundary description. E.g., CUI enclave to external LLM API, SharePoint CUI site to agent memory."
          },
          "data_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$|^[a-f0-9]{128}$",
            "description": "SHA-256 (64 hex chars) or SHA-512 (128 hex chars) hash of the data that crossed the boundary."
          },
          "classification": {
            "type": "string",
            "enum": ["CUI", "CUI_SPECIFIED", "PII", "ITAR", "EXPORT_CONTROL", "PROPRIETARY", "PUBLIC", "UNKNOWN"],
            "description": "Classification of the data at the point of boundary crossing."
          },
          "redacted": {
            "type": "boolean",
            "description": "Whether the data was redacted before crossing the boundary."
          },
          "redaction_method": {
            "type": "string",
            "description": "If redacted, how (e.g., regex_pii_scrub, token_mask, manual)."
          },
          "step_ids": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Which execution steps triggered this data flow."
          },
          "timestamp_utc": {
            "type": "string",
            "format": "date-time"
          },
          "policy_rule_id": {
            "type": "string",
            "description": "Policy rule that authorized or flagged this flow."
          }
        }
      }
    },
    "extensions": {
      "type": "object",
      "description": "Vendor- or org-specific extensions. Must not alter the meaning of required fields.",
      "additionalProperties": true
    }
  },

  "$defs": {

    "sha256_hex": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Lowercase hex-encoded SHA-256 digest (exactly 64 characters)."
    },

    "sha256_or_sha512_hex": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$|^[a-f0-9]{128}$",
      "description": "Lowercase hex-encoded SHA-256 (64 chars) or SHA-512 (128 chars) digest."
    },

    "receipt_header": {
      "type": "object",
      "additionalProperties": false,
      "required": ["receipt_id", "schema_version", "schema_hash", "created_at_utc", "issuer", "status"],
      "properties": {
        "receipt_id": {
          "type": "string",
          "description": "Globally unique receipt ID. UUIDv7 recommended (time-sortable, RFC 9562)."
        },
        "schema_version": {
          "type": "string",
          "const": "0.1.1"
        },
        "schema_hash": {
          "$ref": "#/$defs/sha256_hex",
          "description": "SHA-256 hash of the raw bytes of the published schema.json at the tagged git commit. Ensures two receipts claiming the same schema version are structurally identical. Canonical form is the exact file content at the release tag — no reformatting."
        },
        "created_at_utc": {
          "type": "string",
          "format": "date-time",
          "description": "When this receipt was generated (UTC)."
        },
        "status": {
          "type": "string",
          "enum": ["active", "superseded", "revoked"],
          "default": "active",
          "description": "Lifecycle status. superseded means a corrected receipt exists. revoked means this receipt is no longer trustworthy (e.g., compromised signing key)."
        },
        "superseded_by": {
          "type": "string",
          "description": "Receipt ID of the replacement receipt, if status is superseded."
        },
        "revocation_reason": {
          "type": "string",
          "description": "Human-readable reason for revocation, if status is revoked."
        },
        "revoked_at_utc": {
          "type": "string",
          "format": "date-time",
          "description": "When the receipt was revoked. Required for audit trail when status is revoked."
        },
        "revoked_by": {
          "$ref": "#/$defs/operator_identity",
          "description": "Who revoked this receipt. Provides attribution for the revocation decision."
        },
        "issuer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["organization", "product", "build"],
          "properties": {
            "organization": {
              "type": "string",
              "description": "Org issuing the receipt (usually the customer org)."
            },
            "product": {
              "type": "string",
              "description": "Receipt generator product name (e.g., NeoXFortress AAE)."
            },
            "build": {
              "type": "object",
              "additionalProperties": false,
              "required": ["version", "commit"],
              "properties": {
                "version": { "type": "string" },
                "commit": { "type": "string", "description": "Git commit or build hash of the receipt engine." }
              }
            }
          }
        },
        "receipt_type": {
          "type": "string",
          "enum": ["agent_execution"],
          "default": "agent_execution"
        },
        "related_receipts": {
          "type": "array",
          "description": "Links to related receipts for multi-session, multi-agent, or retry workflows.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["receipt_id", "relationship"],
            "properties": {
              "receipt_id": { "type": "string" },
              "relationship": {
                "type": "string",
                "enum": ["parent", "child", "continuation", "retry", "supersedes"]
              },
              "description": { "type": "string" }
            }
          }
        },
        "labels": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional tags for routing/filing (e.g., CMMC, RFP, SharePoint, CUI)."
        }
      }
    },

    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject", "environment", "time_window"],
      "properties": {
        "subject": { "$ref": "#/$defs/subject" },
        "environment": { "$ref": "#/$defs/environment" },
        "time_window": {
          "type": "object",
          "additionalProperties": false,
          "required": ["started_at_utc", "ended_at_utc"],
          "properties": {
            "started_at_utc": { "type": "string", "format": "date-time" },
            "ended_at_utc": { "type": "string", "format": "date-time" }
          }
        },
        "case": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "case_id": { "type": "string", "description": "Optional incident/ticket/case reference." },
            "case_system": { "type": "string", "description": "E.g., Jira, ServiceNow." }
          }
        }
      }
    },

    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent", "operator"],
      "properties": {
        "agent": { "$ref": "#/$defs/agent_identity" },
        "operator": { "$ref": "#/$defs/operator_identity" },
        "sponsor": {
          "$ref": "#/$defs/operator_identity",
          "description": "Optional: manager/approver sponsoring this run."
        }
      }
    },

    "agent_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_id", "name", "type", "framework"],
      "properties": {
        "agent_id": {
          "type": "string",
          "description": "Stable identifier for the agent (not a human)."
        },
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["assistant", "autonomous_agent", "workflow", "batch_job"]
        },
        "agent_version": {
          "type": "string",
          "description": "Semantic version or release tag of the agent code/configuration."
        },
        "agent_code_hash": {
          "$ref": "#/$defs/sha256_hex",
          "description": "SHA-256 hash of the agent code, prompt templates, and configuration at execution time. Enables regression auditing."
        },
        "framework": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": {
              "type": "string",
              "description": "E.g., custom, OpenAI Agents, LangChain, CrewAI."
            },
            "version": { "type": "string" }
          }
        },
        "purpose": { "type": "string", "description": "Human-readable purpose statement." },
        "owner_team": { "type": "string" },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "language": { "type": "string", "enum": ["python", "javascript", "other"] },
            "language_version": { "type": "string" }
          }
        }
      }
    },

    "operator_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["principal_id", "principal_type"],
      "properties": {
        "principal_id": {
          "type": "string",
          "description": "User ID / service principal ID. Avoid PII; use enterprise identifiers."
        },
        "principal_type": {
          "type": "string",
          "enum": ["human_user", "service_account", "system"]
        },
        "authn": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "idp": { "type": "string", "description": "E.g., Entra ID, Okta." },
            "authn_method": { "type": "string", "description": "E.g., SSO, MFA, key." },
            "session_id": { "type": "string" }
          }
        },
        "role": { "type": "string", "description": "Org role at time of execution." }
      }
    },

    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deployment_model", "host"],
      "properties": {
        "deployment_model": {
          "type": "string",
          "enum": ["local", "self_hosted", "customer_vpc", "saas"],
          "description": "Where the engine ran."
        },
        "host": {
          "type": "object",
          "additionalProperties": false,
          "required": ["hostname_hash", "os", "network_boundary"],
          "properties": {
            "hostname_hash": {
              "$ref": "#/$defs/sha256_hex",
              "description": "SHA-256 hash of hostname (avoid leaking infra names)."
            },
            "os": { "type": "string" },
            "network_boundary": {
              "type": "string",
              "description": "E.g., CUI enclave, Corp IT, Dev sandbox."
            },
            "ip_hash": {
              "$ref": "#/$defs/sha256_hex",
              "description": "Optional SHA-256 hash of host IP."
            }
          }
        },
        "clock": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "time_source": { "type": "string", "description": "E.g., NTP stratum, domain time." },
            "skew_ms": { "type": "integer", "minimum": 0 }
          }
        },
        "deployment_fingerprint": {
          "type": "object",
          "additionalProperties": false,
          "description": "Supply chain provenance for the execution environment. Answers: Which exact container/image + dependencies ran this agent?",
          "properties": {
            "container_image_digest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$",
              "description": "Docker/OCI image digest in standard format (sha256:<64 hex chars>)."
            },
            "sbom_hash": {
              "$ref": "#/$defs/sha256_hex",
              "description": "SHA-256 hash of the Software Bill of Materials for the runtime environment."
            },
            "dependency_lockfile_hash": {
              "$ref": "#/$defs/sha256_hex",
              "description": "SHA-256 hash of the dependency lockfile (e.g., poetry.lock, requirements.txt frozen)."
            }
          }
        }
      }
    },

    "policy_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_id", "policy_version", "controls"],
      "properties": {
        "policy_id": { "type": "string" },
        "policy_version": { "type": "string", "description": "Immutable version identifier." },
        "policy_hash": {
          "$ref": "#/$defs/sha256_hex",
          "description": "SHA-256 hash of the full policy document/config bundle."
        },
        "controls": {
          "type": "object",
          "additionalProperties": false,
          "required": ["logging_mode", "content_capture", "classification_mode"],
          "properties": {
            "logging_mode": {
              "type": "string",
              "enum": ["metadata_only", "metadata_plus_selected_content"],
              "description": "Whether plaintext was stored in-receipt."
            },
            "content_capture": {
              "type": "string",
              "enum": ["none", "redacted", "full"],
              "description": "If content is present, how."
            },
            "classification_mode": {
              "type": "string",
              "const": "rule_based",
              "description": "How sensitivity tags were applied. v0.1.1: rule_based only. Values hybrid and manual_only are reserved for future versions."
            },
            "human_approval_required": { "type": "boolean" },
            "tool_allowlist_enforced": { "type": "boolean" }
          }
        },
        "approvals": {
          "type": "array",
          "description": "Policy-mandated approvals that occurred (if any).",
          "items": { "$ref": "#/$defs/approval_record" }
        }
      }
    },

    "approval_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approval_id", "approved_at_utc", "approver", "scope"],
      "properties": {
        "approval_id": { "type": "string" },
        "approved_at_utc": { "type": "string", "format": "date-time" },
        "approver": { "$ref": "#/$defs/operator_identity" },
        "scope": {
          "type": "string",
          "description": "What was approved (e.g., access SharePoint site X, send email)."
        },
        "decision": { "type": "string", "enum": ["approved", "rejected", "expired"] },
        "notes": { "type": "string" }
      }
    },

    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run", "steps"],
      "properties": {
        "run": {
          "type": "object",
          "additionalProperties": false,
          "required": ["run_id", "run_purpose", "status"],
          "properties": {
            "run_id": { "type": "string", "description": "Execution/run identifier." },
            "run_purpose": { "type": "string" },
            "status": { "type": "string", "enum": ["success", "failed", "partial", "aborted"] },
            "error_summary": { "type": "string" },
            "inputs": {
              "type": "array",
              "description": "Entry inputs to the run (hashed by default).",
              "items": { "$ref": "#/$defs/data_ref" }
            },
            "outputs": {
              "type": "array",
              "description": "Final outputs (hashed by default).",
              "items": { "$ref": "#/$defs/data_ref" }
            }
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/step" }
        }
      }
    },

    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step_id", "timestamp_utc", "type", "parent_step_id", "summary", "artifacts"],
      "properties": {
        "step_id": { "type": "string" },
        "parent_step_id": {
          "type": ["string", "null"],
          "description": "Null for root step."
        },
        "timestamp_utc": { "type": "string", "format": "date-time" },
        "type": {
          "type": "string",
          "enum": ["llm_call", "tool_call", "decision", "human_checkpoint", "guardrail_event"]
        },
        "summary": {
          "type": "string",
          "description": "Human-readable one-liner for auditors."
        },
        "actor": {
          "type": "string",
          "enum": ["agent", "operator", "system"],
          "default": "agent"
        },
        "model": {
          "type": "object",
          "additionalProperties": false,
          "description": "Present when type is llm_call.",
          "properties": {
            "provider": { "type": "string", "description": "E.g., OpenAI, Anthropic." },
            "model_id": { "type": "string" },
            "region": { "type": "string" }
          }
        },
        "tool": {
          "type": "object",
          "additionalProperties": false,
          "description": "Present when type is tool_call.",
          "properties": {
            "tool_name": { "type": "string" },
            "tool_version": { "type": "string" },
            "endpoint_hint": {
              "type": "string",
              "description": "Masked endpoint metadata (no secrets)."
            },
            "permission_scope": {
              "type": "string",
              "description": "What the tool was permitted to do at execution time."
            }
          }
        },
        "human_checkpoint": {
          "type": "object",
          "additionalProperties": false,
          "description": "Structured evidence of human review. Required context for meaningful human oversight arguments in audit. Present when type is human_checkpoint.",
          "properties": {
            "presented_artifact": {
              "$ref": "#/$defs/data_ref",
              "description": "What was shown to the human reviewer (hash or content ref). Critical for proving what the human actually saw before approving."
            },
            "presentation_mode": {
              "type": "string",
              "enum": ["full_output", "summary", "redacted", "diff"],
              "description": "How the artifact was presented to the human."
            },
            "reviewer_action": {
              "type": "string",
              "enum": ["approved", "rejected", "modified", "escalated"],
              "description": "What the human did."
            },
            "review_duration_ms": {
              "type": "integer",
              "minimum": 0,
              "description": "Time spent reviewing. Abnormally low values may indicate rubber-stamping."
            }
          }
        },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "description": "Step-level error detail. Captures what failed and whether the agent recovered.",
          "properties": {
            "code": {
              "type": "string",
              "description": "Machine-readable error code or exception class."
            },
            "message": {
              "type": "string",
              "description": "Human-readable error description. Must not contain secrets or raw stack traces with sensitive paths."
            },
            "recoverable": {
              "type": "boolean",
              "description": "Whether the agent continued execution after this error."
            },
            "recovery_action": {
              "type": "string",
              "description": "What the agent did to recover (e.g., retried with fallback model, skipped step)."
            }
          }
        },
        "artifacts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["inputs", "outputs", "classifications"],
          "properties": {
            "inputs": { "type": "array", "items": { "$ref": "#/$defs/data_ref" } },
            "outputs": { "type": "array", "items": { "$ref": "#/$defs/data_ref" } },
            "classifications": {
              "type": "array",
              "items": { "$ref": "#/$defs/classification_tag" }
            },
            "guardrails": {
              "type": "array",
              "description": "Guardrail events triggered for this step.",
              "items": { "$ref": "#/$defs/guardrail_event" }
            }
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "latency_ms": { "type": "integer", "minimum": 0 },
            "tokens_in": { "type": "integer", "minimum": 0 },
            "tokens_out": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },

    "guardrail_event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_id", "event_type", "action", "timestamp_utc"],
      "properties": {
        "event_id": { "type": "string" },
        "timestamp_utc": { "type": "string", "format": "date-time" },
        "event_type": {
          "type": "string",
          "enum": ["policy_violation", "redaction", "block", "warn", "allow_with_log"]
        },
        "action": { "type": "string", "enum": ["blocked", "redacted", "warned", "allowed"] },
        "reason": { "type": "string" },
        "policy_rule_id": { "type": "string" },
        "attempted_action": {
          "type": "string",
          "description": "What the agent tried to do before being blocked/warned."
        },
        "target_resource_hint": {
          "type": "string",
          "description": "Masked reference to the target resource. No secrets or full paths."
        }
      }
    },

    "data_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref_id", "representation", "hash", "hash_alg"],
      "properties": {
        "ref_id": { "type": "string", "description": "Local reference for linking inputs/outputs." },
        "representation": {
          "type": "string",
          "enum": ["hash_only", "redacted_text", "full_text", "binary_hash"],
          "description": "How data is represented in this receipt."
        },
        "hash": {
          "$ref": "#/$defs/sha256_or_sha512_hex",
          "description": "Digest of the canonical data bytes. Must be valid hex for the selected hash_alg."
        },
        "hash_alg": {
          "type": "string",
          "enum": ["sha256", "sha512"],
          "default": "sha256"
        },
        "content": {
          "type": "string",
          "description": "Optional plaintext content. Only allowed when policy.controls.logging_mode permits it and representation is full_text or redacted_text."
        },
        "content_redaction": {
          "type": "object",
          "additionalProperties": false,
          "description": "Redaction metadata. Required when representation is redacted_text.",
          "properties": {
            "method": { "type": "string", "description": "E.g., regex, token_mask, ner_scrub." },
            "redaction_count": { "type": "integer", "minimum": 0, "description": "Number of redactions applied." }
          }
        },
        "mime_type": { "type": "string" },
        "source_hint": {
          "type": "string",
          "description": "E.g., SharePoint, Local file, Email, User input. No secrets."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "representation": { "const": "hash_only" } }
          },
          "then": {
            "not": { "required": ["content"] },
            "not": { "required": ["content_redaction"] }
          }
        },
        {
          "if": {
            "properties": { "representation": { "const": "redacted_text" } }
          },
          "then": {
            "required": ["content", "content_redaction"]
          }
        },
        {
          "if": {
            "properties": { "representation": { "const": "full_text" } }
          },
          "then": {
            "required": ["content"],
            "not": { "required": ["content_redaction"] }
          }
        },
        {
          "if": {
            "properties": { "representation": { "const": "binary_hash" } }
          },
          "then": {
            "required": ["mime_type"],
            "not": { "required": ["content"] }
          }
        }
      ]
    },

    "classification_tag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tag", "confidence", "method"],
      "properties": {
        "tag": {
          "type": "string",
          "enum": ["CUI", "CUI_SPECIFIED", "PII", "ITAR", "EXPORT_CONTROL", "PROPRIETARY", "PUBLIC", "UNKNOWN"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence score (rule-based can still set 1.0 when rule matches)."
        },
        "method": {
          "type": "string",
          "const": "rule_based",
          "description": "How the tag was assigned. v0.1.1: rule_based only. Values hybrid and manual reserved for future versions."
        },
        "rule_id": { "type": "string", "description": "Identifies which rule produced this tag." },
        "notes": { "type": "string" }
      }
    },

    "data_handling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["storage", "retention", "keys"],
      "properties": {
        "storage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["receipt_storage_location", "content_storage_location"],
          "properties": {
            "receipt_storage_location": {
              "type": "string",
              "enum": ["local_fs", "customer_db", "customer_object_store", "saas"],
              "description": "Where receipts are stored."
            },
            "content_storage_location": {
              "type": "string",
              "enum": ["none", "local_fs", "customer_db", "customer_object_store"],
              "description": "Where full content is stored if captured."
            },
            "byok": { "type": "boolean", "description": "Bring-your-own-key used for encryption at rest." }
          }
        },
        "retention": {
          "type": "object",
          "additionalProperties": false,
          "required": ["receipt_days"],
          "properties": {
            "receipt_days": { "type": "integer", "minimum": 1 },
            "content_days": { "type": "integer", "minimum": 0, "description": "0 means not retained." },
            "retention_enforcement": {
              "type": "object",
              "additionalProperties": false,
              "description": "How retention is actually enforced.",
              "properties": {
                "method": {
                  "type": "string",
                  "enum": ["manual", "automated_cron", "policy_engine"],
                  "description": "Mechanism used to enforce retention limits."
                },
                "last_verified_utc": {
                  "type": "string",
                  "format": "date-time",
                  "description": "Last time retention enforcement was verified."
                }
              }
            }
          }
        },
        "keys": {
          "type": "object",
          "additionalProperties": false,
          "required": ["signing_key_id", "key_management"],
          "properties": {
            "signing_key_id": { "type": "string" },
            "key_management": {
              "type": "string",
              "enum": ["local_kms", "hsm", "customer_kms", "manual"],
              "description": "How signing keys are managed."
            }
          }
        }
      }
    },

    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonicalization", "hash_chain", "signature"],
      "properties": {
        "canonicalization": {
          "type": "object",
          "additionalProperties": false,
          "required": ["method"],
          "properties": {
            "method": {
              "type": "string",
              "enum": ["json_canonicalization_scheme"],
              "description": "How the receipt is canonicalized before hashing/signing. JCS per RFC 8785."
            },
            "notes": { "type": "string" }
          }
        },
        "hash_chain": {
          "type": "object",
          "additionalProperties": false,
          "required": ["alg", "chain", "final_hash"],
          "properties": {
            "alg": { "type": "string", "enum": ["sha256", "sha512"], "default": "sha256" },
            "chain": {
              "type": "array",
              "minItems": 1,
              "description": "Ordered chain of step hashes: H(canonical(step_payload) || prev_hash). First step uses prev_hash of 64 zero hex chars for sha256, 128 for sha512.",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["step_id", "hash", "prev_hash"],
                "properties": {
                  "step_id": { "type": "string" },
                  "hash": { "$ref": "#/$defs/sha256_or_sha512_hex" },
                  "prev_hash": { "$ref": "#/$defs/sha256_or_sha512_hex" }
                }
              }
            },
            "final_hash": { "$ref": "#/$defs/sha256_or_sha512_hex" }
          }
        },
        "merkle": {
          "type": "object",
          "additionalProperties": false,
          "description": "Optional Merkle tree for efficient verification of large executions (hundreds of steps). Linear hash chain is sufficient for typical runs (5-50 steps).",
          "properties": {
            "root": {
              "$ref": "#/$defs/sha256_or_sha512_hex",
              "description": "Merkle root hash."
            },
            "tree_depth": {
              "type": "integer",
              "minimum": 1,
              "description": "Depth of the Merkle tree."
            },
            "proof_paths": {
              "type": "array",
              "description": "Pre-computed proof paths for key steps.",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["step_id", "path"],
                "properties": {
                  "step_id": { "type": "string" },
                  "path": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["hash", "position"],
                      "properties": {
                        "hash": { "$ref": "#/$defs/sha256_or_sha512_hex" },
                        "position": { "type": "string", "enum": ["left", "right"] }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "signature": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "key_id", "value", "signed_at_utc", "signed_payload", "encoding"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["hmac_sha256", "hmac_sha512"],
              "description": "v0.1.1 uses HMAC for tamper-evidence. HMAC is symmetric — signer and verifier share a key, limiting non-repudiation. Asymmetric signatures (ed25519, ecdsa_p256) planned for v0.2."
            },
            "key_id": { "type": "string" },
            "value": { "type": "string", "description": "Base64-encoded signature value." },
            "signed_at_utc": {
              "type": "string",
              "format": "date-time",
              "description": "When the signature was applied. Enables auditors to detect gaps between execution end and signing time."
            },
            "signed_payload": {
              "type": "string",
              "enum": ["canonical_receipt_plus_final_hash"],
              "description": "Explicitly declares what was signed. v0.1.1: always the JCS-canonicalized receipt concatenated with final_hash. Future versions may support other modes."
            },
            "encoding": {
              "type": "string",
              "enum": ["base64"],
              "description": "Encoding of the signature value field."
            },
            "verification": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "procedure": {
                  "type": "string",
                  "description": "Human-readable verification steps for audit packs. Should note HMAC shared-key limitation in v0.1.1."
                }
              }
            }
          }
        },
        "attestations": {
          "type": "array",
          "description": "Optional additional attestations (e.g., operator acknowledgment, supervisor sign-off).",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["attester", "attested_at_utc", "statement"],
            "properties": {
              "attester": { "$ref": "#/$defs/operator_identity" },
              "attested_at_utc": { "type": "string", "format": "date-time" },
              "statement": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
